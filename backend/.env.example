# LIEN Backend env template
# Copy to .env and fill in your values.

# --- Supabase ---
# Project URL (e.g. https://xxxxxxxxxxxx.supabase.co)
SUPABASE_URL=

# Service role key (NOT the anon key). Backend bypasses RLS with this.
SUPABASE_SERVICE_KEY=

# --- Auth ---
# Random secret used to sign JWTs. Generate via: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=changeme

# Access token TTL in seconds (default: 24h)
JWT_EXPIRES_SECONDS=86400

# Nonce TTL in seconds (default: 5 min)
NONCE_EXPIRES_SECONDS=300

# --- AI Verification ---
# When true, AI services return deterministic mock responses without
# calling any external API. Useful for local dev and CI.
AI_MOCK_MODE=true

# --- IPFS (Pinata) ---
# When true, IPFS uploads return a fake CID without calling Pinata.
IPFS_MOCK_MODE=true
PINATA_JWT=

# --- Blockchain ---
# When true, on-chain calls (register, mint, releaseMilestone) are no-ops
# that return a fake tx hash. Useful before contracts are deployed.
CHAIN_MOCK_MODE=true

# Mantle RPC URL
MANTLE_RPC_URL=https://rpc.sepolia.mantle.xyz

# Contract addresses (filled in after deploy)
INVOICE_REGISTRY_ADDRESS=
FINANCING_TOKEN_ADDRESS=
FUNDING_POOL_ADDRESS=
REPUTATION_ORACLE_ADDRESS=

# AI Verifier wallet (called from backend to sign releaseMilestone tx)
AI_VERIFIER_PRIVATE_KEY=

# --- Server ---
CORS_ORIGINS=http://localhost:3000
LOG_LEVEL=INFO
